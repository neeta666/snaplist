# SnapList Backend — Environment Variables
# Copy this file to `.env` and fill in real values. Never commit `.env`.

# --- Server ---
NODE_ENV=development
PORT=5000

# --- CORS ---
# The deployed frontend origin (or localhost during development).
CORS_ORIGIN=http://localhost:5173

# --- Database (Slice 0: connection only, no models yet) ---
# MongoDB Atlas connection string.
MONGO_URI=

# --- Auth (used starting Slice 1 — not required for Slice 0 to boot) ---
JWT_SECRET=
JWT_EXPIRES_IN=2h

# --- Cloudinary (used starting Slice 2) ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Gemini (used starting Slice 3) ---
GEMINI_API_KEY=
