# SnapList Frontend — Environment Variables
# Copy this file to `.env` and fill in real values. Never commit `.env`.
# Vite only exposes variables prefixed with VITE_ to client-side code.

# Backend API origin (no trailing slash, no /api/v1 suffix — the API client
# appends that itself). Point this at the deployed Render URL in production.
VITE_API_BASE_URL=http://localhost:5000
